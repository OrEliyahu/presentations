{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve presentations",
      "type": "shell",
      "command": "python3",
      "args": ["server.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "owner": "presentations-server",
        "pattern": [
          { "regexp": "^$", "file": 1, "location": 2, "message": 3 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Serving presentations from",
          "endsPattern": "^Open http"
        }
      }
    }
  ]
}
